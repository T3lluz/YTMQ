{
  "manifest_version": 3,
  "name": "YTMQ — YouTube Music Connect",
  "version": "1.5.0",
  "description": "Auto-connects YTMQ shared queues on music.youtube.com. Guest picks land in your YouTube Music queue automatically.",
  "minimum_chrome_version": "102",
  "permissions": ["scripting", "storage"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://t3lluz.github.io/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js", "ytm-panel.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://t3lluz.github.io/YTMQ/*"],
      "js": ["site.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YTMQ — YouTube Music Connect"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
